{
  "name": "staruml-mcp-extension",
  "title": "MCP Extension for StarUML",
  "description": "Extends StarUML HTTP API with endpoints for element CRUD, project ops, and command execution — enabling MCP clients to drive StarUML programmatically.",
  "homepage": "https://github.com/ezrabrilliant/staruml-mcp-extension",
  "version": "0.2.2",
  "keywords": [
    "staruml",
    "extension",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "uml"
  ],
  "author": {
    "name": "Ezra Brilliant Konterliem",
    "url": "https://github.com/ezrabrilliant"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezrabrilliant/staruml-mcp-extension.git"
  },
  "bugs": {
    "url": "https://github.com/ezrabrilliant/staruml-mcp-extension/issues"
  },
  "engines": {
    "staruml": ">=7.0.0"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "install:local": "node scripts/install-local.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.39.4",
    "typescript-eslint": "^8.58.2"
  }
}
